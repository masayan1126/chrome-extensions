{
  "name": "rich-markdown-preview-extension",
  "version": "1.0.0",
  "description": "Markdownファイルをカスタマイズ可能なテーマでプレビューするChrome拡張機能",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.22",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "dompurify": "^3.3.2",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "mermaid": "^11.12.1",
    "node-emoji": "^2.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
